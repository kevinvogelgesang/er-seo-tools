DATABASE_URL=file:/var/lib/er-seo-tools/db.sqlite
UPLOADS_DIR=/var/lib/er-seo-tools/uploads
# Hard per-request upload cap checked before multipart parsing.
UPLOAD_MAX_BODY_BYTES=104857600
PORT=3000
# Set to the public URL of this app (used for share link generation)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# App-wide password gate (REQUIRED in production).
# In local dev/test only, leaving this unset enables an auth bypass.
APP_AUTH_PASSWORD=

# HMAC signing secret for auth cookies (REQUIRED in production).
# Must be distinct from APP_AUTH_PASSWORD so a leaked password can't be
# used to forge auth cookies. Generate with:
#   openssl rand -hex 32
# In dev (NODE_ENV !== 'production'), if unset, the app falls back to
# APP_AUTH_PASSWORD or a deterministic dev-only constant.
APP_AUTH_SECRET=

# Chromium ADA audits need network-level SSRF protection in production.
# Preferred: route Chrome through an outbound proxy that blocks private/reserved IPs.
CHROME_PROXY_SERVER=
# Optional bypass list passed to Chrome when CHROME_PROXY_SERVER is set.
CHROME_PROXY_BYPASS_LIST=
# Set to "true" ONLY after you have independently enforced Chromium egress
# isolation at the network/firewall layer — i.e. host or network rules block
# Chromium from reaching private (RFC1918), link-local, loopback, and other
# reserved address ranges. This flag is your assertion that those rules exist;
# the app does not verify them. In production, startup refuses to begin unless
# either CHROME_PROXY_SERVER or CHROMIUM_NETWORK_ISOLATED=true is set.
CHROMIUM_NETWORK_ISOLATED=false

# Pillar analysis JWT signing secret (REQUIRED in production).
# 32+ random bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# In dev (NODE_ENV !== 'production'), if unset, a deterministic dev-only
# constant is used and a one-time warning is logged.
PILLAR_TOKEN_SECRET=

# SEO Audit roadmap handoff JWT signing secret (REQUIRED in production).
# Signs the srt_ tokens for the seo-audit-roadmap skill handoff. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# In dev, if unset, a dev-only constant is used and a warning is logged; in
# production the mint/verify paths throw if it is unset (fail closed).
SEO_ROADMAP_TOKEN_SECRET=

# Keyword research memo handoff JWT signing secret (REQUIRED in production).
# Signs the krt_ tokens for the keyword-strategy-memo skill handoff. Generate
# with the same command as above. Use a value distinct from the others.
KEYWORD_MEMO_TOKEN_SECRET=

# Lighthouse provider selection (for single-page audits).
LIGHTHOUSE_PROVIDER=pagespeed            # pagespeed | local | off
# Optional: raises PSI rate limit from keyless to 25k/day.
PAGESPEED_API_KEY=

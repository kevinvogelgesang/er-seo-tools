// Prisma schema for er-seo-tools
// Migrated from seo-parser-web/backend/prisma/schema.prisma

// After schema changes, run:
//   npx prisma migrate dev --name <migration-name>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  domains     String       @default("[]") // JSON array: ["example.com"]
  createdAt   DateTime     @default(now())
  sessions    Session[]
  adaAudits   AdaAudit[]
  siteAudits  SiteAudit[]
}

model Session {
  id              String            @id
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  status          String            // pending | parsing | complete | error
  error           String?
  files           String            // JSON string: ["file1.csv", "file2.csv"]
  result          String?           // JSON string of AggregatedResult
  siteName        String?           // Domain extracted from crawl URLs
  clientId        Int?              // FK to Client (auto-matched from domains)
  client          Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  shareLinks      ShareLink[]
  pillarAnalyses  PillarAnalysis[]

  @@index([createdAt])
  @@index([status])
  @@index([clientId])
}

model ShareLink {
  id          String   @id @default(cuid())
  sessionId   String
  token       String   @unique
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  accessCount Int      @default(0)

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([token])
}

model AdaAudit {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  url          String
  status       String     // pending | running | axe-complete | complete | error
  error        String?
  result       String?    // JSON string of axe-core AxeResults (nodes truncated to 20 per violation)
  wcagLevel        String     @default("wcag21aa")  // wcag21aa | wcag22aa
  score            Int?                              // 0-100
  shareToken       String?    @unique
  shareExpiresAt   DateTime?
  progress         Int        @default(0)            // 0-100 audit progress
  progressMessage  String     @default("")           // current step label
  runnerType       String     @default("jsdom")      // jsdom | browser
  clientId         Int?
  client       Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  siteAuditId  String?
  siteAudit    SiteAudit? @relation(fields: [siteAuditId], references: [id], onDelete: Cascade)
  lighthouseSummary String?
  lighthouseError   String?
  pdfAudits         PdfAudit[]
  requestedBy       String?    // null on child rows; operator name set at creation for standalone audits

  @@index([createdAt])
  @@index([clientId])
  @@index([status])
  @@index([siteAuditId])
  @@index([shareExpiresAt])
}

model SiteAudit {
  id            String     @id @default(cuid())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  domain        String     // "example.edu" — no scheme, no trailing slash
  status        String     // queued | pending | running | pdfs-running | lighthouse-running | complete | error | cancelled
  error         String?
  pagesTotal    Int        @default(0)
  pagesComplete Int        @default(0)
  pagesError    Int        @default(0)
  pdfsTotal     Int        @default(0)
  pdfsComplete  Int        @default(0)
  pdfsError     Int        @default(0)
  lighthouseTotal     Int        @default(0)
  lighthouseComplete  Int        @default(0)
  lighthouseError     Int        @default(0)
  pdfAudits     PdfAudit[]
  summary       String?    // JSON: SiteAuditSummary (computed once at completion)
  wcagLevel     String     @default("wcag21aa")  // wcag21aa | wcag22aa
  score         Int?                              // 0-100
  runnerType    String     @default("jsdom")      // jsdom | browser
  discoveredUrls String?   // JSON: string[] — pre-discovered URLs stored for queued audits
  clientId      Int?
  client        Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  pageAudits    AdaAudit[]
  batchId       String?
  batch         AuditBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  requestedBy   String?    // operator name from er-operator-name cookie at creation time

  @@index([createdAt])
  @@index([status])
  @@index([clientId])
  @@index([batchId])
}

model PillarAnalysis {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  sessionId           String   @unique // FK to Session (the seo-parser crawl) — one analysis per session
  session             Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status              String   @default("pending") // pending | running | complete | error
  error               String?
  runnerVersion       String   @default("1.0.0")

  // Deterministic outputs (JSON-serialized — SQLite has no native JSON type)
  score               Int?     // 1-10 site fit score
  subscores           String?  // JSON: { contentVolume, topicalConcentration, ... }
  subscorePresence    String?  // JSON: { contentVolume: boolean, ... } — false = N/A in UI
  subscoreContext     String?  // JSON: { informationalCount, programCount, locationCount, validClusterCount }
  dataCompleteness    Float?   // 0.0-1.0 fraction of subscores with real data
  hubRecommendation   String?  // JSON: { primary, alternates: [{format, scoreDelta}] }
  pillarTopics        String?  // JSON: array of cluster groupings
  urlVerdicts         String?  // JSON: array of UrlRecord

  // Phase 2 narrative slot — declared now to avoid migration churn later
  aiNarrative         String?
  narrativeUpdatedAt  DateTime?

  @@index([sessionId, status])
  @@index([status])
  @@index([createdAt])
}

model PdfAudit {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  siteAuditId  String?
  siteAudit    SiteAudit? @relation(fields: [siteAuditId], references: [id], onDelete: Cascade)
  adaAuditId   String?
  adaAudit     AdaAudit?  @relation(fields: [adaAuditId], references: [id], onDelete: Cascade)
  url          String     // normalized URL (query/fragment stripped, host lowercased)
  fileSize     Int?       // bytes
  pageCount    Int?
  status       String     // pending | scanning | complete | error
  issues       String?    // JSON: PdfIssue[]
  scanError    String?

  @@index([siteAuditId])
  @@index([adaAuditId])
  @@unique([siteAuditId, url])
  @@unique([adaAuditId, url])
}

model AuditBatch {
  id         String      @id @default(cuid())
  startedAt  DateTime    @default(now())
  closedAt   DateTime?
  label      String?
  siteAudits SiteAudit[]

  @@index([closedAt])
  @@index([startedAt])
}

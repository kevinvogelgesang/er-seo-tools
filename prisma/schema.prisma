// Prisma schema for er-seo-tools
// Migrated from seo-parser-web/backend/prisma/schema.prisma

// After schema changes, run:
//   npx prisma migrate dev --name <migration-name>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  domains   String    @default("[]") // JSON array: ["example.com"]
  createdAt DateTime  @default(now())
  sessions  Session[]
}

model Session {
  id         String      @id
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  status     String      // pending | parsing | complete | error
  error      String?
  files      String      // JSON string: ["file1.csv", "file2.csv"]
  result     String?     // JSON string of AggregatedResult
  siteName   String?     // Domain extracted from crawl URLs
  clientId   Int?        // FK to Client (auto-matched from domains)
  client     Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  shareLinks ShareLink[]

  @@index([createdAt])
  @@index([status])
  @@index([clientId])
}

model ShareLink {
  id          String   @id @default(cuid())
  sessionId   String
  token       String   @unique
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  accessCount Int      @default(0)

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([token])
}

{
  "name": "er-seo-tools",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "browserslist": [
    "Chrome >= 80",
    "Firefox >= 80",
    "Safari >= 14",
    "Edge >= 80"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "NODE_OPTIONS='--max-old-space-size=3072' next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "rm -rf .smoke-db .smoke-uploads .smoke-reports test-results playwright-report && mkdir -p .smoke-db && NEXT_PUBLIC_APP_URL=http://127.0.0.1:41300 npm run build && playwright test --config=playwright.config.ts",
    "audit:ci": "audit-ci --config ./audit-ci.jsonc",
    "postinstall": "tsx scripts/prewarm-embedding-model.ts || true"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.20",
    "@prisma/client": "^5.22.0",
    "@types/papaparse": "^5.5.2",
    "@xenova/transformers": "^2.17.2",
    "axe-core": "^4.11.1",
    "googleapis": "^173.0.0",
    "jose": "^5.10.0",
    "jsdom": "^25.0.1",
    "lighthouse": "^13.3.0",
    "next": "^15.5.21",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.7.284",
    "pino": "^10.3.1",
    "puppeteer-core": "^24.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.6",
    "server-only": "^0.0.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.4.20",
    "pdf-lib": "^1.17.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "lighthouse": {
      "ws": "^7.5.11",
      "puppeteer-core": {
        "ws": "^8.21.0"
      }
    },
    "brace-expansion@>=2.0.0 <2.1.2": "2.1.2",
    "sharp@<0.35.0": "^0.35.3"
  }
}

{
  "name": "er-seo-tools",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "browserslist": [
    "Chrome >= 80",
    "Firefox >= 80",
    "Safari >= 14",
    "Edge >= 80"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:skill": "bash scripts/build-skill.sh",
    "start": "next start",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "tsx scripts/prewarm-embedding-model.ts || true"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/papaparse": "^5.5.2",
    "@xenova/transformers": "^2.17.2",
    "axe-core": "^4.11.1",
    "jose": "^5.10.0",
    "jsdom": "^25.0.1",
    "lighthouse": "^13.3.0",
    "next": "^15.3.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.7.284",
    "puppeteer-core": "^24.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  }
}
